{
  "name": "omms-pro",
  "version": "0.1.0",
  "description": "OMMS-PRO - 融合记忆宫殿架构的记忆管理系统",
  "author": "",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "omms": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:webui": "cd src/presentation/web-ui && npm run dev",
    "build": "tsc && npm run build:cli && npm run build:webui",
    "build:cli": "tsc -p tsconfig.cli.json",
    "build:webui": "cd src/presentation/web-ui && npm install && npm run build",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "docs": "typedoc --out docs/api src",
    "cli": "tsx src/cli/index.ts",
    "start": "tsx src/cli/index.ts start",
    "start:dev": "tsx watch src/cli/index.ts start --development"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "better-sqlite3": "^11.8.1",
    "compression": "^1.8.1",
    "express": "^4.x",
    "uuid": "^9.x",
    "winston": "^3.x",
    "ws": "^8.18.0",
    "zod": "^3.x"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/express": "^4.x",
    "@types/node": "^20.x",
    "@types/uuid": "^9.x",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.x",
    "@typescript-eslint/parser": "^7.x",
    "eslint": "^8.x",
    "tsx": "^4.x",
    "typedoc": "^0.x",
    "typescript": "^5.x",
    "vitest": "^1.x"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "memory",
    "ai",
    "llm",
    "knowledge-graph",
    "vector-search",
    "memory-palace"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "bugs": {
    "url": ""
  },
  "homepage": ""
}
