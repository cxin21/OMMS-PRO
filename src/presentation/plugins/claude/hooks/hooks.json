{
  "description": "OMMS-PRO memory system hooks for automatic memory recall and capture (JS version)",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/node ${CLAUDE_PLUGIN_ROOT}/hooks/session-start/init-session.cjs",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/node ${CLAUDE_PLUGIN_ROOT}/hooks/pre-response/recall-memory.cjs",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/node ${CLAUDE_PLUGIN_ROOT}/hooks/session-end/capture-session.cjs",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
