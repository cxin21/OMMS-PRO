#!/usr/bin/env bash
# SessionEnd Hook: Final memory capture at session end
# [方案v6] 正确解析 Claude Code hooks 传递的 JSON
#
# Claude Code hooks 通过 stdin 传递的 JSON 包含：
#   - session_id: 会话标识符
#   - transcript_path: 对话文件路径（直接给出！）
#   - cwd: 当前工作目录
#   - hook_event_name: 事件名称
#
# 对话格式:
#   - user消息: {"type":"user","message":{"role":"user","content":"文本"}}
#   - assistant消息: {"type":"assistant","message":{"role":"assistant","content":[{"type":"text","text":"..."}]}}
#
# 环境变量:
#   OMMS_API_URL: OMMS API 端点
#   OMMS_AGENT_ID: Agent 标识符
#   OMMS_SESSION_ID: OMMS session 标识符
#   CLAUDE_PROJECT_DIR: 当前项目目录

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

OMMS_API_PORT="${OMMS_API_PORT:-3000}"
OMMS_API_URL="${OMMS_API_URL:-http://localhost:${OMMS_API_PORT}/api/v1}"
AGENT_ID="${OMMS_AGENT_ID:-claude-code}"
SESSION_ID="${OMMS_SESSION_ID:-session-$(date +%s)}"
PROJECT_DIR="${CLAUDE_PROJECT_DIR:-/tmp}"

# Claude Code 目录
CLAUDE_HOME="${HOME}/.claude"

# 日志函数
log() {
    local level="${1:-info}"
    local message="${2:-}"
    local data="${3:-}"
    node -e "
const url = '${OMMS_API_URL}/system/logs/write';
const payload = JSON.stringify({level:'${level}', message:'${message}', module:'omms-plugin-session-end', data:${data}});
fetch(url, {method:'POST', headers:{'Content-Type':'application/json'}, body:payload})
  .then(r=>r.json())
  .then(d=>{ if(!d.success) console.error('log failed:', d.error); })
  .catch(e=>{ /* silent fail */ });
" > /dev/null 2>&1 || true
}

# ============================================================
# 从 stdin 解析 hook 传递的 JSON
# ============================================================
parse_hook_input() {
    # 从 stdin 读取 hook 输入
    local hook_input
    hook_input=$(cat 2>/dev/null || echo '{}')

    # 提取 session_id
    local claude_session_id=$(echo "$hook_input" | node -e "
const fs = require('fs');
try {
    const json = JSON.parse(fs.readFileSync(0, 'utf8'));
    console.log(json.session_id || '');
} catch (e) {
    console.log('');
}
" 2>/dev/null) || claude_session_id=""

    # 提取 transcript_path（对话文件路径）
    local transcript_path=$(echo "$hook_input" | node -e "
const fs = require('fs');
try {
    const json = JSON.parse(fs.readFileSync(0, 'utf8'));
    console.log(json.transcript_path || '');
} catch (e) {
    console.log('');
}
" 2>/dev/null) || transcript_path=""

    echo "$claude_session_id|$transcript_path"
}

# ============================================================
# 解析 Claude Code .jsonl 文件
# ============================================================
parse_conversation() {
    local jsonl_file="$1"

    if [ ! -f "$jsonl_file" ]; then
        echo "{}"
        return 1
    fi

    node -e "
const fs = require('fs');
const readline = require('readline');

const file = '${jsonl_file}';
const sessionId = '${SESSION_ID}';
const agentId = '${AGENT_ID}';

const rl = readline.createInterface({
    input: fs.createReadStream(file),
    crlfDelay: Infinity
});

const messages = [];

rl.on('line', (line) => {
    try {
        const entry = JSON.parse(line);
        const type = entry.type;

        // user 消息
        if (type === 'user') {
            const msg = entry.message || {};
            let content = msg.content || '';
            if (typeof content !== 'string') content = '';
            if (content.trim()) {
                messages.push({ role: 'user', content: content, timestamp: entry.timestamp });
            }
        }
        // assistant 消息
        else if (type === 'assistant') {
            const msg = entry.message || {};
            if (msg.role === 'assistant') {
                const contentBlocks = msg.content || [];
                let text = '';
                for (const block of contentBlocks) {
                    if (block.type === 'text') {
                        text += block.text || '';
                    }
                }
                if (text.trim()) {
                    messages.push({ role: 'assistant', content: text, timestamp: entry.timestamp });
                }
            }
        }
    } catch (e) {}
});

rl.on('close', () => {
    const pairs = [];
    for (let i = 0; i < messages.length - 1; i++) {
        if (messages[i].role === 'user' && messages[i + 1].role === 'assistant') {
            pairs.push({ user: messages[i].content, assistant: messages[i + 1].content });
        }
    }

    const fullContent = messages.map(m => {
        const prefix = m.role === 'user' ? '【用户】' : '【助手】';
        return prefix + m.content;
    }).join('\n\n');

    const result = {
        sessionId: sessionId,
        agentId: agentId,
        conversationFile: file,
        totalMessages: messages.length,
        interactionPairs: pairs.length,
        fullContent: fullContent,
        pairs: pairs.slice(-50)
    };

    console.log(JSON.stringify(result));
});
" 2>/dev/null
}

# ============================================================
# 捕获对话到 OMMS（使用 node fetch，避免 curl 依赖）
# ============================================================
capture_to_omms() {
    local parse_result="$1"

    local total_messages=$(echo "$parse_result" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.totalMessages || 0); } catch(e) { console.log(0); }" 2>/dev/null)
    local interaction_pairs=$(echo "$parse_result" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.interactionPairs || 0); } catch(e) { console.log(0); }" 2>/dev/null)
    # 使用 base64 编码避免 shell 转义问题
    local full_content_b64=$(echo "$parse_result" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(Buffer.from(d.fullContent || '', 'utf8').toString('base64')); } catch(e) { console.log(''); }" 2>/dev/null)
    local conversation_pairs=$(echo "$parse_result" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(JSON.stringify(d.pairs || [])); } catch(e) { console.log('[]'); }" 2>/dev/null)
    local conv_file=$(echo "$parse_result" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.conversationFile || ''); } catch(e) { console.log(''); }" 2>/dev/null)

    if [ "$total_messages" -eq 0 ]; then
        log "warn" "No messages found in conversation" "{\"file\":\"$conv_file\"}"
        echo "[OMMS] No messages found in conversation file"
        return 1
    fi

    if [ -z "$full_content_b64" ]; then
        log "error" "Failed to encode conversation content" "{\"file\":\"$conv_file\"}"
        echo "[OMMS] Failed to encode conversation content"
        return 1
    fi

    log "info" "Capturing conversation" "{\"messages\":${total_messages},\"interactions\":${interaction_pairs},\"file\":\"$conv_file\",\"contentSize\":\"$(echo "$full_content_b64" | wc -c)\"}"

    # 调用记忆捕获 API（使用 node fetch + base64 编码）
    local capture_result
    capture_result=$(node -e "
const https = require('https');
const http = require('http');

const apiUrl = '${OMMS_API_URL}/memories/capture';
const url = new URL(apiUrl);
const isHttps = url.protocol === 'https:';
const client = isHttps ? https : http;

const payload = JSON.stringify({
    contentBase64: '${full_content_b64}',
    agentId: '${AGENT_ID}',
    sessionId: '${SESSION_ID}',
    type: 'event',
    metadata: {
        source: 'session-end-hook-v6',
        messageCount: ${total_messages},
        interactionPairs: ${interaction_pairs},
        conversationFile: '${conv_file}',
        projectDir: '${PROJECT_DIR}',
        conversationPairs: ${conversation_pairs}
    }
});

const options = {
    hostname: url.hostname,
    port: url.port || (isHttps ? 443 : 3000),
    path: url.pathname,
    method: 'POST',
    headers: {
        'Content-Type': 'application/json',
        'Content-Length': Buffer.byteLength(payload)
    },
    timeout: 120000
};

const req = client.request(options, (res) => {
    let data = '';
    res.on('data', chunk => data += chunk);
    res.on('end', () => {
        // 如果响应为空，标记为 server_empty_error
        if (!data || !data.trim()) {
            console.log(JSON.stringify({success: false, error: 'server_empty_response', details: 'Server returned empty response', statusCode: res.statusCode}));
            return;
        }
        // 如果不是 JSON 格式，标记为 invalid_response
        try {
            JSON.parse(data);
        } catch(e) {
            console.log(JSON.stringify({success: false, error: 'invalid_response', details: data.substring(0, 200), statusCode: res.statusCode}));
            return;
        }
        console.log(data);
    });
});

req.on('error', (e) => {
    console.log(JSON.stringify({success: false, error: 'network_error', details: e.message, code: e.code}));
});

req.on('timeout', () => {
    req.destroy();
    console.log(JSON.stringify({success: false, error: 'timeout', details: 'Request timed out after 120s'}));
});

req.write(payload);
req.end();
" 2>&1) || capture_result="{}"

    # 解析返回结果
    # 如果 capture_result 为空，设置为空对象以避免后续解析出错
    if [ -z "$capture_result" ]; then
        capture_result='{}'
    fi

    local success=$(echo "$capture_result" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.success ? 'true' : 'false'); } catch(e) { console.log('false'); }" 2>/dev/null)

    if [ "$success" = "true" ]; then
        local memory_uid=$(echo "$capture_result" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.data?.uid || 'N/A'); } catch(e) { console.log('N/A'); }" 2>/dev/null)
        log "info" "Session memory captured successfully" "{\"memoryUid\":\"${memory_uid}\"}"
        echo "[OMMS] Session captured: ${interaction_pairs} interactions, ${total_messages} messages. Memory: ${memory_uid}"
        return 0
    else
        local error=$(echo "$capture_result" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.error || 'unknown'); } catch(e) { console.log('parse_error'); }" 2>/dev/null)
        local details=$(echo "$capture_result" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.details || d.stack || ''); } catch(e) { console.log(''); }" 2>/dev/null)
        local status_code=$(echo "$capture_result" | node -e "try { const d=JSON.parse(require('fs').readFileSync(0,'utf8')); console.log(d.statusCode || ''); } catch(e) { console.log(''); }" 2>/dev/null)
        log "error" "Session memory capture failed" "{\"error\":\"${error}\",\"details\":\"${details}\",\"statusCode\":\"${status_code}\"}"
        echo "[OMMS] Failed to capture: ${error} (${status_code}) - ${details}"
        return 1
    fi
}

# ============================================================
# 主逻辑
# ============================================================
main() {
    log "info" "=== SESSION END HOOK START (v6) ===" "{\"agentId\":\"${AGENT_ID}\",\"sessionId\":\"${SESSION_ID}\",\"projectDir\":\"${PROJECT_DIR}\"}"

    # 解析 hook 传递的信息
    local hook_info
    hook_info=$(parse_hook_input)
    local claude_session_id=$(echo "$hook_info" | cut -d'|' -f1)
    local transcript_path=$(echo "$hook_info" | cut -d'|' -f2)

    log "debug" "Hook input parsed" "{\"sessionId\":\"${claude_session_id}\",\"transcriptPath\":\"${transcript_path}\"}"

    # 确定对话文件路径
    local conv_file=""
    if [ -n "$transcript_path" ] && [ -f "$transcript_path" ]; then
        conv_file="$transcript_path"
        log "info" "Using transcript_path from hook" "{\"file\":\"$conv_file\"}"
    else
        log "warn" "No transcript_path provided or file not found" "{}"
        echo "[OMMS] No transcript path provided"
        exit 0
    fi

    if [ ! -f "$conv_file" ]; then
        log "error" "Conversation file not found" "{\"file\":\"$conv_file\"}"
        echo "[OMMS] Conversation file not found: $conv_file"
        exit 0
    fi

    local file_size=$(wc -c < "$conv_file" 2>/dev/null || echo "0")
    local line_count=$(wc -l < "$conv_file" 2>/dev/null || echo "0")

    log "info" "Found conversation file" "{\"file\":\"${conv_file}\",\"size\":${file_size},\"lines\":${line_count}}"

    if [ "$file_size" -lt 100 ]; then
        log "warn" "Conversation file too small" "{\"file\":\"$conv_file\"}"
        exit 0
    fi

    # 解析对话
    local parse_result
    parse_result=$(parse_conversation "$conv_file")

    # 捕获到 OMMS
    capture_to_omms "$parse_result"

    # 异步: 触发用户画像更新（使用 node fetch）
    node -e "
const apiUrl = '${OMMS_API_URL}/profile/${AGENT_ID}/persona/build';
const url = new URL(apiUrl);
const isHttps = url.protocol === 'https:';
const client = isHttps ? require('https') : require('http');

const payload = JSON.stringify({sessionId: '${SESSION_ID}'});
const options = {
    hostname: url.hostname,
    port: url.port || (isHttps ? 443 : 3000),
    path: url.pathname,
    method: 'POST',
    headers: {'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(payload)}
};

const req = client.request(options, (res) => {
    let data = '';
    res.on('data', chunk => data += chunk);
    res.on('end', () => { /* fire and forget */ });
});
req.on('error', () => { /* silent fail */ });
req.write(payload);
req.end();
" > /dev/null 2>&1 &

    log "info" "=== SESSION END HOOK END ===" "{\"agentId\":\"${AGENT_ID}\"}"
    exit 0
}

main
