#!/usr/bin/env bash
# PreResponse Hook: Recall relevant memories before generating response
# 执行时机: Agent 生成响应之前
#
# Claude Code 通过 stdin 传递:
#   - session_id: 当前会话标识符
#   - transcript_path: 对话文件路径
#
# 环境变量:
#   OMMS_API_URL: OMMS API 端点
#   OMMS_AGENT_ID: Agent 标识符
#   OMMS_SESSION_ID: 会话标识符

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"

OMMS_API_PORT="${OMMS_API_PORT:-3000}"
OMMS_API_URL="${OMMS_API_URL:-http://localhost:${OMMS_API_PORT}/api/v1}"
AGENT_ID="${OMMS_AGENT_ID:-claude-code}"
SESSION_ID="${OMMS_SESSION_ID:-session-$(date +%s)}"

# 日志函数
log() {
    local level="${1:-info}"
    local message="${2:-}"
    local data="${3:-}"
    node -e "
const url = '${OMMS_API_URL}/system/logs/write';
const payload = JSON.stringify({level:'${level}', message:'${message}', module:'omms-plugin-recall-memory', data:${data}});
fetch(url, {method:'POST', headers:{'Content-Type':'application/json'}, body:payload})
  .then(r=>r.json())
  .then(d=>{ if(!d.success) console.error('log failed:', d.error); })
  .catch(e=>{ /* silent fail */ });
" > /dev/null 2>&1 || true
}

# ============================================================
# 从 transcript 文件获取最后一条 user 消息
# ============================================================
get_last_user_message() {
    local transcript_path="$1"

    if [ ! -f "$transcript_path" ]; then
        echo ""
        return
    fi

    # 读取最后几行，查找最新的 user 消息
    tail -100 "$transcript_path" | node -e "
const fs = require('fs');
const readline = require('readline');

const lines = fs.readFileSync(0, 'utf8').split('\\n').filter(l => l.trim());

let lastUserMessage = '';
for (let i = lines.length - 1; i >= 0; i--) {
    try {
        const entry = JSON.parse(lines[i]);
        if (entry.type === 'user') {
            const msg = entry.message || {};
            let content = msg.content || '';
            if (typeof content === 'string' && content.trim()) {
                lastUserMessage = content;
                break;
            }
        }
    } catch (e) {}
}

console.log(lastUserMessage.substring(0, 2000));
" 2>/dev/null || echo ""
}

# ============================================================
# 主逻辑
# ============================================================
main() {
    log "info" "=== PRE-RESPONSE RECALL ===" "{\"sessionId\":\"${SESSION_ID}\"}"

    # 从 stdin 读取钩子输入
    local hook_input
    hook_input=$(cat 2>/dev/null || echo '{}')

    # 解析 transcript_path
    local transcript_path=$(echo "$hook_input" | node -e "
const fs = require('fs');
try {
    const json = JSON.parse(fs.readFileSync(0, 'utf8'));
    console.log(json.transcript_path || '');
} catch (e) { console.log(''); }
" 2>/dev/null) || transcript_path=""

    if [ -z "$transcript_path" ] || [ ! -f "$transcript_path" ]; then
        log "debug" "No transcript path available" "{\"transcriptPath\":\"$transcript_path\"}"
        exit 0
    fi

    # 获取最后一条 user 消息
    local user_prompt
    user_prompt=$(get_last_user_message "$transcript_path")

    if [ -z "$user_prompt" ]; then
        log "debug" "No user message found in transcript" "{}"
        exit 0
    fi

    log "debug" "Found user prompt" "{\"promptLength\":${#user_prompt}}"

    # 调用记忆召回 API (使用 node fetch + JSON.stringify 防止 JSON 注入)
    local recall_result
    recall_result=$(OMMS_RECALL_PROMPT="$user_prompt" node -e "
const url = '${OMMS_API_URL}/memories/recall';
const body = JSON.stringify({
  query: process.env.OMMS_RECALL_PROMPT || '',
  limit: 3,
  agentId: '${AGENT_ID}'
});
fetch(url, {method:'POST', headers:{'Content-Type':'application/json'}, body})
  .then(r=>r.json())
  .then(d=>console.log(JSON.stringify(d)))
  .catch(e=>console.log('{}'));
" 2>/dev/null) || recall_result="{}"

    # 检查是否有召回的记忆
    local memory_count=$(echo "$recall_result" | node -e "
try {
    const d = JSON.parse(require('fs').readFileSync(0, 'utf8'));
    console.log(d.data?.memories?.length || 0);
} catch(e) { console.log(0); }
" 2>/dev/null) || memory_count=0

    if [ "$memory_count" -gt 0 ]; then
        log "info" "Found relevant memories" "{\"count\":${memory_count}}"

        # 输出额外的上下文 (Claude Code 会处理)
        echo ""
        echo "<OMMS_RECALL>"
        echo "$recall_result" | node -e "
const fs = require('fs');
const data = JSON.parse(fs.readFileSync(0, 'utf8'));
const memories = data.data?.memories || [];
if (memories.length > 0) {
    console.log('## Relevant Memories from Previous Sessions');
    memories.forEach((m, i) => {
        console.log((i+1) + '. [' + (m.type || 'fact') + '] ' + (m.content?.substring(0, 200) || ''));
    });
}
" 2>/dev/null || true
        echo "</OMMS_RECALL>"
    fi

    log "info" "=== PRE-RESPONSE RECALL END ===" "{\"sessionId\":\"${SESSION_ID}\",\"memoriesFound\":${memory_count}}"
    exit 0
}

main
