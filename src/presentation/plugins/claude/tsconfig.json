{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "../../..",
    "declaration": true,
    "baseUrl": "../../..",
    "paths": {
      "@shared/*": ["shared/*"],
      "@core/*": ["core/*"]
    }
  },
  "include": ["server/**/*"],
  "exclude": ["node_modules"]
}